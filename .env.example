# ── 필수 ───────────────────────────────────────────────
# PostgreSQL connection string
DATABASE_URL=""
# JWT 세션 비밀키 (운영 시 반드시 긴 랜덤 문자열로)
JWT_SECRET="change-this-to-a-long-random-string"
# cron 보호 키 (Vercel Cron 헤더 또는 ?key= 쿼리)
CRON_SECRET=""
# 앱 URL (이메일 링크 생성용 — 미설정 시 VERCEL_URL fallback)
NEXT_PUBLIC_APP_URL="https://portzone-invest-platform.vercel.app"

# ── 옵션: 파일 저장소 ─────────────────────────────────
# Vercel Storage → Blob 생성 시 자동 추가됨
BLOB_READ_WRITE_TOKEN=""

# ── 옵션: 이메일 (Resend) ─────────────────────────────
# https://resend.com — 도메인 인증 후 EMAIL_FROM 변경
RESEND_API_KEY=""
EMAIL_FROM="PortZone <onboarding@resend.dev>"

# ── 옵션: 에러 모니터링 (Sentry) ──────────────────────
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_DSN=""

# ── 옵션: Rate limit (Upstash Redis) ───────────────────
# 미설정 시 in-memory fallback (단일 인스턴스 동작)
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ── 추후 연동 ─────────────────────────────────────────
# 알림톡 (Solapi)
SOLAPI_API_KEY=""
SOLAPI_API_SECRET=""
KAKAO_PFID=""
# 결제 (토스페이먼츠)
TOSS_CLIENT_KEY=""
TOSS_SECRET_KEY=""
