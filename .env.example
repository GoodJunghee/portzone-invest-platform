# PostgreSQL connection string (Vercel Postgres / Supabase / Neon)
# 예시: postgresql://user:password@host:5432/dbname?sslmode=require
DATABASE_URL=""

# JWT 세션 비밀키 — 배포 시 반드시 긴 랜덤 문자열로 변경
JWT_SECRET="change-this-to-a-long-random-string"

# cron 보호 키 (Vercel Cron이 /api/cron/alimtalk 호출 시 ?key=... 로 검증)
CRON_SECRET=""

# 알림톡 (추후 연동 — Solapi 추천)
SOLAPI_API_KEY=""
SOLAPI_API_SECRET=""
KAKAO_PFID=""

# PG (추후 연동)
TOSS_CLIENT_KEY=""
TOSS_SECRET_KEY=""
