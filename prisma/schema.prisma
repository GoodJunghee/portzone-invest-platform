generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String    @id @default(cuid())
  email           String    @unique
  name            String
  phone           String
  passwordHash    String
  role            String    @default("USER") // USER | ADMIN
  emailVerified   Boolean   @default(false)
  emailVerifiedAt DateTime?
  deletedAt       DateTime?
  referralCode    String?   @unique
  referredById    String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  subscriptions      Subscription[]
  notifications      NotificationLog[]
  reportAccess       ReportAccess[]
  watchlist          Watchlist[]
  notifyPref         NotifyPreference?
  verificationTokens VerificationToken[]
  passwordResets     PasswordResetToken[]
  referredBy         User?               @relation("Referrals", fields: [referredById], references: [id])
  referrals          User[]              @relation("Referrals")
}

model Subscription {
  id          String    @id @default(cuid())
  userId      String
  category    String    // DAYTRADE | SWING | LONGTERM | ALLINONE
  markets     String    // CSV: "KOSPI,KOSDAQ,UPBIT"
  billingType String    // MONTHLY | YEARLY
  priceKrw    Int
  status      String    @default("PENDING") // PENDING | TRIAL | ACTIVE | CANCELLED | EXPIRED
  trialEndsAt DateTime?
  startDate   DateTime?
  endDate     DateTime?
  cancelledAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Report {
  id          String   @id @default(cuid())
  title       String
  category    String
  market      String
  summary     String
  content     String
  fileUrl     String?
  fileName    String?
  fileSize    Int?
  publishedAt DateTime @default(now())
  createdAt   DateTime @default(now())

  access ReportAccess[]
}

model ReportAccess {
  id       String   @id @default(cuid())
  userId   String
  reportId String
  viewedAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  report Report @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@unique([userId, reportId])
}

model NotificationLog {
  id        String    @id @default(cuid())
  userId    String
  channel   String    // ALIMTALK | SMS | EMAIL
  category  String
  market    String
  title     String
  message   String
  status    String    @default("QUEUED") // QUEUED | SENT | FAILED
  sentAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Watchlist {
  id        String   @id @default(cuid())
  userId    String
  market    String
  symbol    String
  name      String
  memo      String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, market, symbol])
}

model NotifyPreference {
  id              String   @id @default(cuid())
  userId          String   @unique
  alimtalkEnabled Boolean  @default(true)
  emailEnabled    Boolean  @default(true)
  preMarketOpen   Boolean  @default(true)
  preMarketClose  Boolean  @default(true)
  urgentSignal    Boolean  @default(true)
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AlimtalkJob {
  id          String    @id @default(cuid())
  category    String
  market      String
  title       String
  message     String
  scheduledAt DateTime
  status      String    @default("SCHEDULED")
  totalCount  Int       @default(0)
  sentCount   Int       @default(0)
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
}

/// 이메일 인증 토큰 (가입 시)
model VerificationToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  email     String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
}

/// 비밀번호 재설정 토큰
model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
}
