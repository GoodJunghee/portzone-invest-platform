generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String    @id @default(cuid())
  email           String    @unique
  name            String
  phone           String
  passwordHash    String
  role            String    @default("USER") // USER | ADMIN
  emailVerified   Boolean   @default(false)
  emailVerifiedAt DateTime?
  deletedAt       DateTime?
  referralCode    String?   @unique
  referredById    String?
  trialUsedAt     DateTime? // trial 1회만 부여
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  subscriptions      Subscription[]
  notifications      NotificationLog[]
  reportAccess       ReportAccess[]
  watchlist          Watchlist[]
  notifyPref         NotifyPreference?
  verificationTokens VerificationToken[]
  passwordResets     PasswordResetToken[]
  referredBy         User?               @relation("Referrals", fields: [referredById], references: [id])
  referrals          User[]              @relation("Referrals")
  coupons            Coupon[]
  refundRequests     RefundRequest[]
  rewardsAsReferrer  ReferralReward[]    @relation("AsReferrer")
  rewardsAsReferred  ReferralReward[]    @relation("AsReferred")
}

model Subscription {
  id              String    @id @default(cuid())
  userId          String
  category        String    // DAYTRADE | SWING | LONGTERM | ALLINONE
  markets         String    // CSV: "KOSPI,KOSDAQ,UPBIT"
  billingType     String    // MONTHLY | YEARLY | TRIAL
  priceKrw        Int
  status          String    @default("PENDING") // PENDING | TRIAL | ACTIVE | CANCELLED | EXPIRED | REFUNDED
  trialEndsAt     DateTime?
  startDate       DateTime?
  endDate         DateTime?
  cancelledAt     DateTime?
  refundedAt      DateTime?
  refundAmountKrw Int?
  appliedCouponId String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  refundRequests RefundRequest[]
  appliedCoupon  Coupon?         @relation(fields: [appliedCouponId], references: [id])
}

model Report {
  id          String   @id @default(cuid())
  title       String
  category    String
  market      String
  summary     String
  content     String
  fileUrl     String?
  fileName    String?
  fileSize    Int?
  isPublic    Boolean  @default(false) // 비로그인 사용자도 열람 가능 (샘플)
  isSample    Boolean  @default(false) // 랜딩 페이지에 노출되는 대표 샘플
  publishedAt DateTime @default(now())
  createdAt   DateTime @default(now())

  access ReportAccess[]

  @@index([isPublic, isSample])
}

model ReportAccess {
  id       String   @id @default(cuid())
  userId   String
  reportId String
  viewedAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  report Report @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@unique([userId, reportId])
}

model NotificationLog {
  id            String    @id @default(cuid())
  userId        String
  channel       String    // ALIMTALK | SMS | EMAIL
  category      String
  market        String
  title         String
  message       String
  status        String    @default("QUEUED") // QUEUED | SENT | FAILED
  priority      String    @default("NORMAL") // NORMAL | HIGH (관심종목 매치)
  matchedSymbol String?   // 관심종목 매치 시 종목 코드
  sentAt        DateTime?
  createdAt     DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Watchlist {
  id        String   @id @default(cuid())
  userId    String
  market    String
  symbol    String
  name      String
  memo      String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, market, symbol])
}

model NotifyPreference {
  id              String   @id @default(cuid())
  userId          String   @unique
  alimtalkEnabled Boolean  @default(true)
  emailEnabled    Boolean  @default(true)
  preMarketOpen   Boolean  @default(true)
  preMarketClose  Boolean  @default(true)
  urgentSignal    Boolean  @default(true)
  watchlistOnly   Boolean  @default(false) // 관심종목 시그널만 받기
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AlimtalkJob {
  id          String    @id @default(cuid())
  category    String
  market      String
  symbol      String?   // 추천 종목 코드 (관심종목 매칭용)
  title       String
  message     String
  scheduledAt DateTime
  status      String    @default("SCHEDULED")
  totalCount  Int       @default(0)
  sentCount   Int       @default(0)
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
}

model VerificationToken {
  id        String    @id @default(cuid())
  userId    String
  token     String    @unique
  email     String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
}

/// 할인/무료 쿠폰 (리퍼럴 보상, 프로모션 등)
model Coupon {
  id            String    @id @default(cuid())
  userId        String
  code          String    @unique
  type          String    // FREE_MONTH | PERCENT | FIXED_AMOUNT
  valueInt      Int       // FREE_MONTH=개월수, PERCENT=%(0~100), FIXED_AMOUNT=원
  description   String
  source        String    @default("PROMO") // PROMO | REFERRAL_REFERRER | REFERRAL_REFERRED
  status        String    @default("ACTIVE") // ACTIVE | USED | EXPIRED
  expiresAt     DateTime?
  usedAt        DateTime?
  appliedSubId  String?
  createdAt     DateTime  @default(now())

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscriptions Subscription[]

  @@index([userId, status])
}

/// 리퍼럴 보상 이벤트 추적
model ReferralReward {
  id           String   @id @default(cuid())
  referrerId   String
  referredId   String
  referrerCouponId String?
  referredCouponId String?
  status       String   @default("ISSUED") // ISSUED | CONFIRMED (피추천인 첫 결제 시) | REVOKED
  createdAt    DateTime @default(now())

  referrer User @relation("AsReferrer", fields: [referrerId], references: [id], onDelete: Cascade)
  referred User @relation("AsReferred", fields: [referredId], references: [id], onDelete: Cascade)

  @@unique([referrerId, referredId])
}

/// 보고서 템플릿 (관리자가 자주 쓰는 양식 저장)
model ReportTemplate {
  id          String   @id @default(cuid())
  name        String   // 템플릿 이름 (예: "단타 KOSPI 일일 리포트")
  category    String
  market      String
  titlePattern String  // 제목 패턴 (변수 치환 가능)
  summary     String
  content     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

/// 블로그/뉴스 포스트 (SEO 콘텐츠)
model BlogPost {
  id            String    @id @default(cuid())
  slug          String    @unique
  title         String
  excerpt       String    // 목록·OpenGraph용 요약 (최대 200자 권장)
  content       String    // 본문 HTML
  coverImageUrl String?
  category      String    // MARKET_ANALYSIS | STRATEGY | NEWS | GUIDE
  tags          String?   // CSV
  authorName    String    @default("PortZone")
  status        String    @default("DRAFT") // DRAFT | PUBLISHED | ARCHIVED
  viewCount     Int       @default(0)
  publishedAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([status, publishedAt])
  @@index([category])
}

/// 알림톡 템플릿 라이브러리
model AlimtalkTemplate {
  id          String   @id @default(cuid())
  name        String   // 템플릿 이름 (예: "장 시작 전 단타 추천")
  category    String
  market      String?  // 시장 미지정 시 모든 시장 사용 가능
  title       String   // 알림 제목 (변수 치환 가능)
  body        String   // 본문 (변수 치환 가능 — {{symbol}}, {{name}}, {{buy}}, {{target}}, {{stop}})
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

/// 환불 요청
model RefundRequest {
  id            String    @id @default(cuid())
  userId        String
  subscriptionId String
  reason        String
  amountKrw     Int       // 시스템이 계산한 환불 예정 금액
  status        String    @default("PENDING") // PENDING | APPROVED | REJECTED | REFUNDED
  reviewedAt    DateTime?
  reviewedBy    String?   // admin user id
  reviewNote    String?
  refundedAt    DateTime?
  createdAt     DateTime  @default(now())

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscription Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([userId, status])
}
